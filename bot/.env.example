# ── Telegram ──────────────────────────────────────────────────────────────────
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Groq (free tier AI) ───────────────────────────────────────────────────────
# Get a free API key from https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Google Cloud / BigQuery ───────────────────────────────────────────────────
# Local: leave blank — ADC (gcloud auth application-default login) is used automatically.
# Cloud (Railway etc.): paste the full service account JSON as a single line.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"soy-sauce-tracker",...}

# BigQuery config (defaults match the project)
BQ_PROJECT=soy-sauce-tracker
BQ_DATASET=raw
BQ_TABLE=raw_telegram_leads

# ── Brevo (email sending) ─────────────────────────────────────────────────────
# Get a free API key from https://brevo.com → sign up → SMTP & API → API Keys
BREVO_API_KEY=your_brevo_api_key_here
# The "From" address — verify it in Brevo → Senders & IP → Senders
REPORT_FROM_EMAIL=Soy Sauce Bot <atsushi_sakai1208@hotmail.com>
REPORT_FROM_NAME=Soy Sauce Bot

# ── Gemini usage cap ──────────────────────────────────────────────────────────
# Max Groq AI calls per day (free tier = 14400/day; set lower for safety)
GROQ_DAILY_LIMIT=200
# Max conversation turns per user session (prevents infinite loops)
GROQ_TURN_LIMIT=10
