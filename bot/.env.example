# ── Telegram ──────────────────────────────────────────────────────────────────
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Google Gemini (free tier) ─────────────────────────────────────────────────
# Get a free API key from https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud / BigQuery ───────────────────────────────────────────────────
# If you use Application Default Credentials (gcloud auth application-default login),
# you do NOT need to set this. Only set it if you have a service account JSON key.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# BigQuery config (defaults match the project)
BQ_PROJECT=soy-sauce-tracker
BQ_DATASET=raw
BQ_TABLE=raw_telegram_leads
